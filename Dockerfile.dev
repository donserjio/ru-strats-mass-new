FROM node:20-slim

WORKDIR /app

# Install dependencies first for better layer caching
COPY package.json package-lock.json ./
RUN npm ci

# Copy project files
COPY . .

ENV NODE_ENV=development
ENV PORT=5000
ENV CHOKIDAR_USEPOLLING=true
ENV WATCHPACK_POLLING=true

EXPOSE 5000

CMD ["npm", "run", "dev"]
